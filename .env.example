# Token del bot de Telegram
TELEGRAM_BOT_TOKEN=tu_token_de_telegram_aqui

# URL de la API de Firefly III
FIREFLY_III_API_URL=http://firefly_iii_core:8080

# Token de acceso personal de Firefly III
FIREFLY_III_API_TOKEN=tu_token_personal_de_firefly

# Lista de cuentas que quieres ocultar (separadas por coma)
HIDE_ACCOUNTS=Cuenta1,Cuenta2

# Usuarios autorizados por ID de Telegram (opcional — si vacío, acceso abierto)
# Si queda vacío, el bot loguea el user_id de cada acceso permitido para ayudarte
# a completar esta variable. Luego configurala y reiniciá el bot.
ALLOWED_USER_IDS=

# Zona horaria para las transacciones (default: Europe/Lisbon)
TIMEZONE=Europe/Lisbon

# Nivel de log: DEBUG, INFO, WARNING, ERROR o CRITICAL
LOG_LEVEL=WARNING
